{
  "name": "elohim-protocol-tests",
  "version": "1.0.0",
  "description": "BDD specification tests for the Elohim Protocol - demonstrates what needs to be implemented",
  "private": true,
  "scripts": {
    "test": "jest --coverage --verbose",
    "test:public-observer": "jest --testPathPattern=public-observer --verbose",
    "test:governance": "jest --testPathPattern=governance --verbose",
    "test:value-scanner": "jest --testPathPattern=value-scanner --verbose",
    "test:social-medium": "jest --testPathPattern=social-medium --verbose",
    "test:autonomous-entity": "jest --testPathPattern=autonomous-entity --verbose",
    "validate-features": "node scripts/validate-features.js",
    "report:generate": "node scripts/generate-report.js",
    "export:features": "node scripts/export-features.js"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@cucumber/gherkin": "^27.0.0",
    "@cucumber/messages": "^24.0.1",
    "jest": "^29.7.0",
    "jest-cucumber": "^4.0.0",
    "jest-html-reporter": "^3.10.2",
    "cucumber-html-reporter": "^7.1.1",
    "glob": "^10.3.10",
    "chalk": "^4.1.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/step-definitions/**/*.test.js"
    ],
    "coverageDirectory": "reports/coverage",
    "coverageReporters": [
      "text",
      "html",
      "json-summary"
    ],
    "reporters": [
      "default",
      [
        "jest-html-reporter",
        {
          "pageTitle": "Elohim Protocol Specification Test Report",
          "outputPath": "reports/html/index.html",
          "includeFailureMsg": true,
          "includeConsoleLog": true,
          "theme": "darkTheme",
          "logo": "",
          "executionMode": "reporter",
          "dateFormat": "yyyy-mm-dd HH:MM:ss"
        }
      ]
    ],
    "collectCoverageFrom": [
      "step-definitions/**/*.js"
    ],
    "verbose": true,
    "testTimeout": 10000
  }
}
